# ============================================
# InterviewPro - Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Server hostname/IP (used for browser → backend URLs)
# Set this to the IP or domain of the machine running Docker
# Examples: localhost, 192.168.1.100, interviewpro.vn
SERVER_HOST=localhost

# --- Gemini AI ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# --- PostgreSQL ---
POSTGRES_PASSWORD=1234

# --- JWT ---
JWT_SECRET=change-this-to-a-random-secret-in-production
